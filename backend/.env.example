DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.run.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.run\.app$
CSRF_TRUSTED_ORIGINS=https://*.run.app,http://localhost:4200,http://127.0.0.1:4200
FRONTEND_STUDENT_LOGIN_URL=http://localhost:4200/login

POSTGRES_DB=psicologia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

ADMIN_EMAIL=ficho@cue.edu.co
ADMIN_PASSWORD=admin123
DB_ENGINE=postgres

OPENAI_API_KEY=configure-this-in-google-secret-manager
# Optional when mounting the secret as a file instead of an environment variable:
# OPENAI_API_KEY_FILE=/secrets/openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_SECONDS=45
