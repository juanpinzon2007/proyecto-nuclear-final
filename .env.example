DJANGO_SECRET_KEY=change-me-use-google-secret-manager
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.run.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.run.app
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.run\.app$
FRONTEND_STUDENT_LOGIN_URL=https://YOUR-FRONTEND-SERVICE-URL/login

DB_ENGINE=postgres
POSTGRES_DB=psicologia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-google-secret-manager
POSTGRES_HOST=YOUR_CLOUD_SQL_OR_POSTGRES_HOST
POSTGRES_PORT=5432

ADMIN_EMAIL=ficho@cue.edu.co
ADMIN_PASSWORD=change-me-use-google-secret-manager

OPENAI_API_KEY=configure-this-in-google-secret-manager
# Optional when mounting the secret as a file instead of an environment variable:
# OPENAI_API_KEY_FILE=/secrets/openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT_SECONDS=45
